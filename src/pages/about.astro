---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About · ${SITE_TITLE}`} description={`About ${AUTHOR.name}.`} />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				I'm {AUTHOR.name}, an infra engineer working on large-scale ML and LLM systems. This site
				is a place to keep my projects, writing, and notes.
			</p>
			<p>
				[Longer bio: a paragraph or two on background, what you're working on, what you find
				interesting, what you're looking for next.]
			</p>
			<p>
				Reach me at <a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>

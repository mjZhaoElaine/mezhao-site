---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { AUTHOR, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`CV · ${SITE_TITLE}`} description={`CV of ${AUTHOR.name}.`} />
	</head>
	<body>
		<Header />
		<main>
			<header class="cv-head">
				<h1>{AUTHOR.name}</h1>
				<p>
					{AUTHOR.email} · <a href={AUTHOR.github}>GitHub</a> ·
					<a href={AUTHOR.linkedin}>LinkedIn</a> ·
					<a href="/cv.pdf">PDF</a>
				</p>
			</header>

			<section>
				<h2>Summary</h2>
				<p>
					[One paragraph. Years of experience, areas of depth (LLM serving, distributed training,
					etc.), what you're looking for next.]
				</p>
			</section>

			<section>
				<h2>Experience</h2>
				<article>
					<h3>
						LinkedIn <span class="muted">· Infra Engineer · 20XX – present</span>
					</h3>
					<ul>
						<li>[Bullet: what you built, with a number. Past tense even if ongoing.]</li>
						<li>[Bullet.]</li>
						<li>[Bullet.]</li>
					</ul>
				</article>
				<article>
					<h3>
						Previous role <span class="muted">· Title · 20XX – 20XX</span>
					</h3>
					<ul>
						<li>[Bullet.]</li>
					</ul>
				</article>
			</section>

			<section>
				<h2>Open source</h2>
				<ul>
					<li>[repo-name] — one-line description, with star count if interesting.</li>
				</ul>
			</section>

			<section>
				<h2>Education</h2>
				<p>[School, degree, year.]</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.cv-head {
		margin-bottom: 2rem;
	}
	.muted {
		color: #888;
		font-weight: normal;
	}
	section {
		margin-bottom: 1.5rem;
	}
	article {
		margin-bottom: 1rem;
	}
	h3 {
		margin-bottom: 0.25em;
	}
</style>

---
import { AUTHOR } from '../consts';
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {AUTHOR.name}. <a href="/rss.xml">RSS</a></p>
	<div class="social-links">
		<a href={AUTHOR.github} target="_blank" rel="noopener">GitHub</a>
		<a href={AUTHOR.linkedin} target="_blank" rel="noopener">LinkedIn</a>
		<a href={`mailto:${AUTHOR.email}`}>Email</a>
	</div>
</footer>

<style>
	footer {
		width: 680px;
		max-width: calc(100% - 2.5em);
		margin: auto;
		padding: 1.75em 0 3em;
		border-top: 1px solid var(--border);
		color: var(--faint);
		font-size: 0.88rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5em 1em;
	}
	footer p {
		margin: 0;
	}
	footer a {
		color: var(--muted);
		text-decoration: none;
	}
	footer a:hover {
		color: var(--ink);
	}
	.social-links {
		display: flex;
		gap: 1em;
	}
</style>

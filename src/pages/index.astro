---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { AUTHOR, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

// Highlighted projects — edit me. Keep the list short (3-5).
const projects = [
	{
		title: 'Differential serving for CPU→GPU ads ranking',
		blurb:
			'Dual-fire architecture that scores live ad requests on a TensorFlow CPU champion and a new PyTorch GPU candidate in parallel, with async overlap, asymmetric resolution, and a three-gate routing decision (experiment, tmax, config kill switch) so we can A/B a new realtime inference stack without risking the served path.',
		href: '/projects#differential-serving',
	},
	{
		title: 'Early Stage Ranking infra (Two-Tower at ~10M scale)',
		blurb:
			'Co-designed the infra to collapse retrieval + first-pass ranking into a single Two-Tower scoring layer over the active creative corpus, with nearline embedding generation, version alignment between member and creative towers, and dot-product scoring on sharded indexers. First end-to-end experiment delivered an over-20% CTR lift.',
		href: '/projects#early-stage-ranking',
	},
	{
		title: 'Entity cache rewrite for the ads serving fleet',
		blurb:
			'Lead-authored the RFCs and rollout that moved hundreds of ads-serving hosts off direct Oracle reads onto a per-account-partitioned Kafka + Couchbase pipeline, decoupled the in-memory cache from the indexer, and shipped a portable cache library so adjacent ads services could onboard without a rewrite.',
		href: '/projects#entity-cache-rewrite',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>{AUTHOR.name}</h1>
				<p class="lede">
					Infra engineer at LinkedIn working on latency-sensitive realtime ML inference
					for ads scoring and ranking at internet scale. Currently going deep on LLM
					inference serving — paged attention, continuous batching, disaggregated serving.
				</p>
				<p class="lede">
					Notes, projects, and writing on infra for ML systems at scale.
				</p>
				<p>
					<a href="/cv">CV</a> · <a href="/blog">Writing</a> ·
					<a href={AUTHOR.github}>GitHub</a> ·
					<a href={AUTHOR.linkedin}>LinkedIn</a> ·
					<a href={`mailto:${AUTHOR.email}`}>{AUTHOR.email}</a>
				</p>
			</section>

			<section>
				<h2>Selected projects</h2>
				<ul class="project-list">
					{
						projects.map((p) => (
							<li>
								<a href={p.href}>
									<strong>{p.title}</strong>
								</a>{' '}
								— {p.blurb}
							</li>
						))
					}
				</ul>
				<p><a href="/projects">More projects →</a></p>
			</section>

			<section>
				<h2>Recent writing</h2>
				{posts.length === 0 ? (
					<p><em>No posts yet — first post coming soon.</em></p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<FormattedDate date={post.data.pubDate} />{' '}
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</li>
						))}
					</ul>
				)}
				<p><a href="/blog">All writing →</a></p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 2.5rem;
	}
	.hero h1 {
		margin-bottom: 0.25em;
	}
	.lede {
		font-size: 1.05rem;
		line-height: 1.6;
	}
	section {
		margin-bottom: 2rem;
	}
	.project-list,
	.post-list {
		list-style: none;
		padding: 0;
	}
	.project-list li,
	.post-list li {
		margin-bottom: 0.5em;
	}
</style>

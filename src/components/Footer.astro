---
import { AUTHOR } from '../consts';
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {AUTHOR.name}. <a href="/rss.xml">RSS</a></p>
	<div class="social-links">
		<a href={AUTHOR.github} target="_blank" rel="noopener">GitHub</a>
		<a href={AUTHOR.linkedin} target="_blank" rel="noopener">LinkedIn</a>
		<a href={`mailto:${AUTHOR.email}`}>Email</a>
	</div>
</footer>

<style>
	footer {
		padding: 2em 1em 4em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	footer p {
		margin: 0 0 0.5em 0;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
	}
	.social-links a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
